# Netlify Forms
# This project uses Netlify's built-in form handling

# Optional: For form notifications via email
# Set up form notifications in Netlify dashboard:
# Site Settings → Forms → Notifications → Add notification
# Then configure email recipients

# Supabase Authentication
# Get these values from your Supabase project:
# Project Settings → API → Project URL and anon key
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Database
# Connection string for PostgreSQL database
# Get password from Settings → Database → Password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.gtsphhpvssivxuldfrfq.supabase.co:5432/postgres
